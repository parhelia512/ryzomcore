<interface_config>
	<root id="interface" x="0" y="0" w="800" h="600" active="true" />

	
<group type="container"
	id="hide_n_hype_main"
	x="600" y="500" w="400" h="500" posref="MM MM"
	max_w="1600" pop_max_w="1600"
	max_h="1600" pop_max_h="1600"
	min_w="26" pop_min_w="26"
	min_h="26" pop_min_h="26"
	title=""
	global_color="true"
	global_color_over="true"
	header_active="false"
	right_button="false"
	options="layer0_pad"
	movable="true"
	active="false"
	opened="true"
	openable="false"
	resizer="false">
	
	<group id="header_closed" x="0" y="0" w="0" h="0" posref="TL TL"></group>
	<group id="header_opened" x="0" y="0" w="120" h="300" wmin="5" sizeref="w" posref="TL TL">
	<group type="webig_html"
				id="html"
				url="https://app.ryzom.com/app_arcc/index.php"
				title_prefix=""
				sizeref="wh"
				x="0"
				y="0"
				w="0"
				h="0"
				background_color="0 0 0 255"
				error_color="255 240 48 255"
				link_color="240 155 100 255"
				text_color="210 210 210 255"
				h1_color="255 255 255 255"
				h2_color="255 255 255 255"
				h3_color="255 255 255 255"
				h4_color="255 255 255 255"
				h5_color="255 255 255 255"
				h6_color="100 255 100 255"
				text_font_size="10"
				h1_font_size="20"
				h2_font_size="18"
				h3_font_size="16"
				h4_font_size="14"
				h5_font_size="12"
				h6_font_size="10"
				paragraph_begin_space="1"
				multi_line_space_factor="0.25"
				td_begin_space="16"
				li_begin_space="4"
				ul_begin_space="12"
				li_indent="0"
				ul_indent="30"
				checkbox_bitmap_normal="w_slot_on.tga"
				checkbox_bitmap_pushed="w_opacity_on.tga"
				checkbox_bitmap_over=""
				background_bitmap_view="black2"
				home="https://app.ryzom.com/app_arcc/index.php"
				browse_next_time="true"
				form_text_area_group="edit_box_widget_multiline">
					<group type="list"
						id="text_list"
						fontsize="30"
						posref="TL TL"
						posparent="black"
						x="0"
						y="0"
						space="0"
						sizeref="hw"
						w="0"
						h="0"
						maxelements="2000" />
			</group>
	</group>
</group>

<group id="load_pars_json"
		type="container"
		w="36"
		h="36"
		global_color="false"
		global_color_over="true"
		header_active="false"
		right_button="false"
		movable="false"
		active="false"
		resizer="false"
		opened="false"
		openable="false">
		
		<view type="bitmap" posref="MM MM" id="display_loading_img" w="36" h="36" y="0" x="0" texture="ico_time.tga" />
</group>

<group type="container"
	id="hide_n_hype_ask_abort"
	x="600" y="500" w="400" h="500" posref="MM MM"
	max_w="1600" pop_max_w="1600"
	max_h="1600" pop_max_h="1600"
	min_w="26" pop_min_w="26"
	min_h="26" pop_min_h="26"
	title=""
	global_color="true"
	global_color_over="true"
	header_active="false"
	right_button="false"
	options="layer0_pad"
	movable="true"
	active="false"
	opened="true"
	openable="false"
	resizer="false">
	
	<group id="header_closed" x="0" y="0" w="0" h="0" posref="TL TL"></group>
	<group id="header_opened" x="0" y="0" w="120" h="300" wmin="5" sizeref="w" posref="TL TL">
	<group type="webig_html"
				id="html"
				url="https://app.ryzom.com/app_arcc/index.php"
				title_prefix=""
				sizeref="wh"
				x="0"
				y="0"
				w="0"
				h="0"
				background_color="0 0 0 255"
				error_color="255 240 48 255"
				link_color="240 155 100 255"
				text_color="210 210 210 255"
				h1_color="255 255 255 255"
				h2_color="255 255 255 255"
				h3_color="255 255 255 255"
				h4_color="255 255 255 255"
				h5_color="255 255 255 255"
				h6_color="100 255 100 255"
				text_font_size="10"
				h1_font_size="20"
				h2_font_size="18"
				h3_font_size="16"
				h4_font_size="14"
				h5_font_size="12"
				h6_font_size="10"
				paragraph_begin_space="1"
				multi_line_space_factor="0.25"
				td_begin_space="16"
				li_begin_space="4"
				ul_begin_space="12"
				li_indent="0"
				ul_indent="30"
				checkbox_bitmap_normal="w_slot_on.tga"
				checkbox_bitmap_pushed="w_opacity_on.tga"
				checkbox_bitmap_over=""
				background_bitmap_view="black2"
				home="https://app.ryzom.com/app_arcc/index.php"
				browse_next_time="true"
				form_text_area_group="edit_box_widget_multiline">
					<group type="list"
						id="text_list"
						fontsize="30"
						posref="TL TL"
						posparent="black"
						x="0"
						y="0"
						space="0"
						sizeref="hw"
						w="0"
						h="0"
						maxelements="2000" />
			</group>
	</group>
</group>

<tree node="hide_n_hype_main"></tree>
<tree node="load_pars_json" />
<tree node="hide_n_hype_ask_abort" />

<template name="hide_n_hype_timer" keep="true" x="0" y="0" font_size="30" text_color="0 185 0 255" timer="00:00" id="">
			<group id="#id" posref="MM MM" w="100" h="50" x="#x" y="#y" sizeref="" render_layer="1">
				<view type="text" posref="TL TL"
					id="text"
					x="0"
					y="0"
					hardtext="#timer"
					fontsize="#font_size"
					color="#text_color"
					shadow="true"
					global_color="false" />
		   </group>
		</template>
		
		<template name="hide_n_hype_text" keep="true" x="0" y="0" font_size="30" text_color="0 185 0 255" hardtext="" id="" w="60" h="20">
			<group id="#id" posref="MM MM" w="#w" h="#h" x="#x" y="#y" sizeref="" render_layer="1">
				<view type="text" posref="TL TL"
					id="text"
					x="0"
					y="0"
					hardtext="#hardtext"
					fontsize="#font_size"
					color="#text_color"
					shadow="true"
					global_color="false" />
		   </group>
		</template>
		
		<template name="hide_n_hype_button" keep="true" x="0" y="0">
			<group id="hide_n_hype_button" posref="MM MM" w="100" h="50" x="#x" y="#y" sizeref="" render_layer="1">
			  <ctrl type="button"
				style="text_button_header"
				button_type="toggle_button"
				id="hide_n_hype_button_accept"
				x="0"
				y="-4"
				active="false"
				tx_normal="r2ed_icon_rotate.tga"
				tx_pushed="r2ed_icon_rotate.tga"
				tooltip="uiBrowseRefresh"
				onclick_l="lua"
				params_l="debug('test')" />
			 </group>
		</template>
		
		
			<template name="hide_n_hype_button_images" render_layer1="1" render_layer2="2" keep="true" tooltip="" w="40" h="40" bg="" img1="" x="0" y="0" lua_function="" ctrl_active="true" >
			<group id="#id" posref="MM MM" w="#w" h="#h" x="#x" y="#y" sizeref="" render_layer="#render_layer1">
				<view type="bitmap" posref="ML ML" render_layer="#render_layer1"
					id="back"
					x="2"
					y="0"
					w="#w"
					h="#h"
					scale="true"
					resize="true"
					texture="#bg"
					global_color="false" />
				<view type="bitmap" posref="ML ML" render_layer="#render_layer2"
					id="img1"
					x="2"
					y="0"
					w="#w"
					h="#h"
					scale="true"
					resize="true"
					texture="#img1"
					global_color="false" />
			   <ctrl id="ctrl" active="#ctrl_active" type="button" button_type="push_button" global_color_normal="false" posref="ML ML" x="1" y="0"
					tx_normal="W_slot_blason_over.tga"
					tx_over="W_slot_blason_over.tga"
					tx_pushed="W_slot_blason_over.tga"
					scale="true"
					w="#w"
					h="#h"
					tooltip="#tooltip"
					color="255 255 255 0"
					col_over="255 255 255 255"
					col_pushed="255 255 255 255"
					render_layer="0"
					onclick_l="lua"
					params_l="Ryzhide:#lua_function('#id')" />
		   </group>
		</template>
		
		<template name="hide_n_hype_only_images" render_layer1="1" keep="true" tooltip="" w="16" h="16" img1="" x="0" y="0" >
			<group id="#id" posref="MM MM" w="#w" h="#h" x="#x" y="#y" sizeref="" render_layer="#render_layer1">
				<view type="bitmap" posref="ML ML" render_layer="#render_layer1"
					id="img1"
					x="2"
					y="0"
					w="#w"
					h="#h"
					scale="true"
					resize="true"
					texture="#img1"
					global_color="false" />
				<ctrl id="ctrl" type="button" button_type="push_button" global_color_normal="false" posref="ML ML" x="1" y="0"
					scale="true"
					w="#w"
					h="#h"
					tooltip="#tooltip"
					color="0 0 0 0"
					render_layer="0" />
			</group>
		</template>
		
	<lua file="hide_n_hype.lua" />
</interface_config>