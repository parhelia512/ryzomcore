{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "luabind",
  "version": "0.9.1",
  "description": "Luabind is a library that helps you create bindings between C++ and Lua. Fork to merge in C++11 and Lua 5.4 support.",
  "homepage": "https://github.com/ryzom/luabind",
  "license": "MIT",
  "dependencies": [
    "boost-dynamic-bitset",
    "boost-foreach",
    "boost-integer",
    "boost-lexical-cast",
    "boost-mpl",
    "boost-smart-ptr",
    "boost-utility",
    "lua",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ]
}
